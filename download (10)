*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{margin:0;}
.app,.onb,.boot{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;color:#eceaf6;background:radial-gradient(120% 80% at 50% -10%, #1c1c22, #0a0a0c 60%);min-height:100vh;display:flex;flex-direction:column;padding-top:env(safe-area-inset-top);}
.boot{align-items:center;justify-content:center;}.boot-in{opacity:.6;}
.app{max-width:520px;margin:0 auto;width:100%;position:relative;}
.top{display:flex;align-items:center;justify-content:space-between;padding:12px 16px 8px;}
.who{display:flex;align-items:center;gap:10px;background:none;border:none;color:inherit;cursor:pointer;}
.avatar{border-radius:50%;display:grid;place-items:center;box-shadow:0 4px 14px rgba(0,0,0,.35);flex:none;}
.who-txt{display:flex;flex-direction:column;align-items:flex-start;line-height:1.15;}
.who-name{font-weight:800;font-size:16px;}.who-mot{font-size:11px;color:#b3add6;}
.top-stats{display:flex;gap:8px;}
.coinpill,.streakpill{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:6px 12px;font-weight:700;font-size:14px;font-variant-numeric:tabular-nums;}
.coinpill{color:#ffd66b;}
.lvlbar{display:flex;align-items:center;gap:10px;padding:4px 16px 12px;}
.lvl{font-weight:800;font-size:12px;letter-spacing:.06em;color:var(--accent2);}
.xptrack{flex:1;height:9px;background:rgba(255,255,255,.1);border-radius:6px;overflow:hidden;}
.xpfill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:6px;transition:width .5s;}
.xpnum{font-size:11px;color:#9d97c4;font-variant-numeric:tabular-nums;}
.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:0 16px 110px;}
.page{display:flex;flex-direction:column;gap:14px;padding-top:4px;}
.hello h1{margin:6px 0 2px;font-size:24px;font-weight:800;letter-spacing:-.02em;}
.hello-sub{margin:0;color:#b3add6;font-size:14px;}
.spotlight{display:flex;align-items:center;gap:12px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:12px;padding:14px 16px;color:#fff;box-shadow:0 10px 24px -10px var(--accent);}
.spot-emoji{font-size:30px;}.spot-title{font-weight:800;font-size:15px;}.spot-sub{font-size:12px;opacity:.92;margin-top:2px;}
.mission{text-align:left;border:none;border-radius:12px;padding:16px;cursor:pointer;color:#fff;box-shadow:0 8px 20px -12px rgba(0,0,0,.6);transition:transform .1s;}
.mission:active{transform:scale(.98);}
.mission.read{background:linear-gradient(135deg,#ff3d3d,#c62828);}
.mission.school{background:linear-gradient(135deg,#3ddc84,#1f9d6a);}
.mission.math{background:linear-gradient(135deg,#00e5ff,#7c5cff);}
.mission.done{filter:saturate(.5) brightness(.8);}
.mi-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.mi-tag{font-weight:800;font-size:15px;display:flex;align-items:center;gap:8px;}
.prio{font-style:normal;font-size:9px;letter-spacing:.1em;background:rgba(0,0,0,.25);padding:2px 7px;border-radius:8px;}
.mi-time{font-size:12px;background:rgba(255,255,255,.22);padding:3px 9px;border-radius:12px;}
.mi-title{font-size:17px;font-weight:700;margin-bottom:10px;}
.mi-foot{display:flex;justify-content:space-between;align-items:center;font-size:13px;opacity:.95;}.mi-go{font-weight:800;}
.day-done{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:16px;text-align:center;}
.dd-emoji{font-size:30px;}.dd-txt{font-size:14px;margin:6px 0 12px;color:#cfcbe9;}
.session{padding-bottom:90px;}
.sess-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.sess-tools{display:flex;align-items:center;gap:8px;}
.back{background:rgba(255,255,255,.08);border:none;color:#dcd8f2;border-radius:20px;padding:8px 14px;font-size:14px;font-weight:600;cursor:pointer;}
.timer{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);color:var(--accent2);border-radius:20px;padding:8px 14px;font-size:15px;font-weight:700;font-variant-numeric:tabular-nums;cursor:pointer;}
.active-tip{background:rgba(255,255,255,.06);border-radius:12px;padding:10px 14px;font-size:13px;color:#cfcbe9;}
.passage{background:#fcf9f3;color:#26242e;border-radius:12px;padding:18px;}
.genre{display:inline-block;font-size:10px;letter-spacing:.16em;text-transform:uppercase;font-weight:800;color:#0a0a0c;background:#00e5ff;padding:3px 9px;border-radius:6px;}
.ptitle{font-family:Georgia,serif;font-size:21px;margin:10px 0 10px;font-weight:700;}
.ptext{font-family:Georgia,serif;font-size:17px;line-height:1.7;margin:0;color:#36333f;}
.q{background:rgba(255,255,255,.05);border-radius:12px;padding:15px;}
.qtext{font-size:16px;font-weight:600;margin:0 0 12px;line-height:1.45;}.qtext b{color:var(--accent2);}
.opts{display:flex;flex-direction:column;gap:8px;}
.opt{display:flex;align-items:center;gap:11px;text-align:left;border:1.5px solid rgba(255,255,255,.14);background:rgba(255,255,255,.04);border-radius:13px;padding:13px;font-size:16px;color:#eceaf6;cursor:pointer;min-height:52px;}
.opt:active{background:rgba(255,255,255,.1);}
.ol{display:grid;place-items:center;width:26px;height:26px;border-radius:8px;background:rgba(255,255,255,.12);font-size:13px;font-weight:800;flex:none;}
.opt.sel{border-color:var(--accent);background:rgba(124,92,255,.18);}.opt.sel .ol{background:var(--accent);}
.opt.ok{border-color:#3ddc84;background:rgba(61,220,132,.16);}.opt.ok .ol{background:#3ddc84;color:#08230f;}
.opt.no{border-color:#ff6b6b;background:rgba(255,107,107,.16);}.opt.no .ol{background:#ff6b6b;}
.why{font-size:13px;color:#a59fce;margin:10px 0 0;font-style:italic;}
.open{width:100%;border:1.5px solid rgba(255,255,255,.14);background:rgba(255,255,255,.04);border-radius:12px;padding:12px;font-size:16px;color:#eceaf6;font-family:inherit;resize:vertical;}
.open:focus{outline:2px solid var(--accent);}
.model{margin-top:10px;background:rgba(124,92,255,.14);border-radius:12px;padding:12px;font-size:14px;line-height:1.5;color:#d6d0f5;}
.mrow{background:rgba(255,255,255,.05);border-radius:14px;padding:12px 14px;}
.mrow-main{display:flex;align-items:center;gap:10px;}
.mnum{font-family:ui-monospace,Menlo,monospace;font-size:13px;color:var(--accent2);font-weight:700;width:20px;flex:none;}
.mprompt{font-family:ui-monospace,Menlo,monospace;font-size:15px;flex:1;color:#eceaf6;}
.minput{width:84px;border:1.5px solid rgba(255,255,255,.16);background:rgba(255,255,255,.06);border-radius:10px;padding:11px;font-size:16px;font-family:ui-monospace,Menlo,monospace;text-align:right;color:#fff;flex:none;}
.minput:focus{outline:2px solid var(--accent);}
.minput.ok{border-color:#3ddc84;background:rgba(61,220,132,.18);}
.minput.no{border-color:#ff6b6b;background:rgba(255,107,107,.18);}
.mmark{font-size:18px;font-weight:800;width:16px;}
.solbtn{margin-top:8px;border:1px solid rgba(255,255,255,.16);background:none;color:var(--accent2);border-radius:9px;padding:6px 12px;font-size:12px;font-weight:600;cursor:pointer;}
.msol{margin-top:8px;background:rgba(255,255,255,.06);border-radius:10px;padding:10px 12px;font-size:13px;font-family:ui-monospace,Menlo,monospace;color:#cfcbe9;line-height:1.5;}
.portal-btn{display:block;text-align:center;text-decoration:none;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border-radius:14px;padding:15px;font-weight:800;font-size:16px;}
.portal-missing{background:rgba(255,255,255,.06);border-radius:12px;padding:14px;font-size:13px;color:#b3add6;text-align:center;}
.checkrow{display:flex;align-items:center;gap:12px;text-align:left;width:100%;border:1.5px solid rgba(255,255,255,.14);background:rgba(255,255,255,.04);border-radius:14px;padding:15px;font-size:15px;color:#eceaf6;cursor:pointer;min-height:58px;}
.checkrow.on{border-color:#3ddc84;background:rgba(61,220,132,.14);}
.cbox{display:grid;place-items:center;width:28px;height:28px;border-radius:8px;border:2px solid rgba(255,255,255,.3);font-weight:800;color:#08230f;background:transparent;flex:none;}
.checkrow.on .cbox{background:#3ddc84;border-color:#3ddc84;}
.sw-done{background:rgba(61,220,132,.14);border:1px solid #3ddc84;border-radius:14px;padding:18px;text-align:center;font-size:15px;color:#bff3d4;}
.sticky-cta{position:sticky;bottom:0;padding:12px 0 calc(12px + env(safe-area-inset-bottom));background:linear-gradient(to top,#161228 70%,transparent);}
.cta{width:100%;border:none;border-radius:14px;padding:16px;font-size:16px;font-weight:800;color:#fff;background:linear-gradient(135deg,var(--accent),var(--accent2));cursor:pointer;box-shadow:0 8px 22px -8px var(--accent);}
.cta:active{transform:scale(.99);}.cta:disabled{opacity:.45;}
.cta.done{background:rgba(255,255,255,.12);box-shadow:none;}.cta.small{width:auto;padding:11px 18px;font-size:14px;}
.tabbar{position:fixed;bottom:0;left:0;right:0;max-width:520px;margin:0 auto;display:flex;background:rgba(20,16,38,.94);backdrop-filter:blur(12px);border-top:1px solid rgba(255,255,255,.08);padding-bottom:env(safe-area-inset-bottom);}
.tabbtn{flex:1;background:none;border:none;color:#7d77a6;padding:10px 0 8px;display:flex;flex-direction:column;align-items:center;gap:2px;cursor:pointer;}
.tabbtn.on{color:var(--accent2);}.tabe{font-size:21px;}.tabl{font-size:11px;font-weight:600;}
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:#fff;color:#1a1530;padding:12px 18px;border-radius:24px;font-size:14px;font-weight:700;box-shadow:0 10px 30px rgba(0,0,0,.4);z-index:50;max-width:90%;text-align:center;}
.onb{justify-content:center;padding:24px 18px;}
.onb-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:24px;max-width:460px;margin:auto;width:100%;}
.onb-prog{height:6px;background:rgba(255,255,255,.12);border-radius:6px;overflow:hidden;margin-bottom:18px;}
.onb-prog>div{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .3s;}
.onb-step{font-size:12px;color:#9d97c4;margin:0 0 8px;letter-spacing:.04em;}
.onb-q{font-size:22px;font-weight:800;margin:0 0 18px;line-height:1.25;}.onb-q.center{text-align:center;}
.onb-opts{display:flex;flex-direction:column;gap:10px;}
.onb-opt{text-align:left;border:1.5px solid rgba(255,255,255,.14);background:rgba(255,255,255,.04);border-radius:14px;padding:16px;font-size:16px;color:#eceaf6;cursor:pointer;min-height:56px;}
.onb-opt:active{background:rgba(124,92,255,.2);border-color:var(--accent);}
.result-emoji{font-size:64px;text-align:center;}
.onb-blurb{text-align:center;font-size:16px;color:#cfcbe9;margin:6px 0;}
.onb-reward{text-align:center;font-size:14px;color:#a59fce;background:rgba(124,92,255,.12);border-radius:12px;padding:12px;margin:14px 0 20px;}
.avatar-preview{display:flex;justify-content:center;margin:8px 0 16px;}
.name-in,.url-in{width:100%;border:1.5px solid rgba(255,255,255,.16);background:rgba(255,255,255,.05);border-radius:12px;padding:14px;font-size:16px;color:#fff;}
.name-in{text-align:center;font-size:17px;margin-bottom:8px;}.name-in:focus,.url-in:focus{outline:2px solid var(--accent);}
.pick-lbl{font-size:13px;color:#9d97c4;margin:14px 0 8px;font-weight:600;}
.pick-lbl .hint{color:#6f6a95;font-weight:400;}
.hint{font-size:11px;color:#6f6a95;font-weight:400;}
.pick-grid{display:flex;gap:10px;flex-wrap:wrap;}
.pick-grid.wide{display:grid;grid-template-columns:repeat(6,1fr);}
.pick-face{width:52px;height:52px;border-radius:14px;border:1.5px solid rgba(255,255,255,.14);background:rgba(255,255,255,.05);font-size:26px;cursor:pointer;display:grid;place-items:center;}
.pick-face.on{border-color:var(--accent);background:rgba(124,92,255,.22);}
.pick-color{width:52px;height:52px;border-radius:14px;border:2px solid rgba(255,255,255,.2);cursor:pointer;color:#fff;font-weight:800;font-size:18px;}
.pick-color.on{border-color:#fff;}
.onb-foot{font-size:12px;color:#7d77a6;text-align:center;margin:14px 0 0;}
.rw-title{font-size:24px;font-weight:800;margin:8px 0 4px;}
.rw-tabs{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;-webkit-overflow-scrolling:touch;}
.rwtab{flex:none;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.05);color:#b3add6;border-radius:20px;padding:9px 16px;font-size:14px;font-weight:600;cursor:pointer;}
.rwtab.on{background:var(--accent);border-color:var(--accent);color:#fff;}
.rw-body{display:flex;flex-direction:column;gap:10px;}
.bigstat{text-align:center;padding:10px 0;}
.bs-num{display:block;font-size:54px;font-weight:800;line-height:1;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.bs-lbl{font-size:13px;color:#9d97c4;letter-spacing:.1em;text-transform:uppercase;}
.statline{background:rgba(255,255,255,.05);border-radius:12px;padding:13px 16px;font-size:15px;}
.badge-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}
.badge{display:flex;flex-direction:column;align-items:center;gap:6px;background:rgba(255,255,255,.05);border-radius:14px;padding:18px 10px;text-align:center;}
.badge.locked{opacity:.45;}.badge.got{border:1.5px solid var(--accent);background:rgba(124,92,255,.12);}
.be{font-size:30px;}.bl{font-size:12px;font-weight:600;color:#cfcbe9;}
.theme-list{gap:8px;}
.theme-row{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,.05);border:1.5px solid transparent;border-radius:14px;padding:12px 14px;cursor:pointer;color:#eceaf6;}
.theme-row.on{border-color:var(--accent);}
.swatch{width:34px;height:34px;border-radius:9px;flex:none;}
.theme-name{flex:1;text-align:left;font-weight:600;font-size:15px;}.theme-cost{font-size:13px;font-weight:700;color:#ffd66b;}
.level-list{display:flex;flex-direction:column;gap:8px;}
.level-row{display:flex;flex-direction:column;align-items:flex-start;background:rgba(255,255,255,.05);border:1.5px solid transparent;border-radius:14px;padding:13px 16px;cursor:pointer;color:#eceaf6;}
.level-row.on{border-color:var(--accent);background:rgba(124,92,255,.12);}
.lv-name{font-weight:700;font-size:16px;}.lv-sub{font-size:12px;color:#9d97c4;margin-top:2px;}
.store-intro{font-size:13px;color:#a59fce;margin:0 0 6px;}
.store-row{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,.05);border-radius:13px;padding:12px 14px;}
.store-row.edit{font-size:14px;}.store-emoji{font-size:24px;}.store-label{flex:1;font-size:15px;}
.redeem{border:none;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border-radius:20px;padding:9px 15px;font-weight:800;font-size:13px;cursor:pointer;}
.redeem:disabled{opacity:.4;background:rgba(255,255,255,.1);}
.cost-tag{font-size:13px;color:#ffd66b;font-weight:700;}
.rm{border:none;background:rgba(255,107,107,.18);color:#ff8a8a;border-radius:8px;width:30px;height:30px;cursor:pointer;font-size:14px;}
.ticket{background:rgba(255,255,255,.05);border-left:3px solid var(--accent);border-radius:10px;padding:11px 13px;font-size:14px;margin-bottom:6px;}
.ticket.flag{border-left-color:#ffb020;}
.tk-date{display:block;font-size:11px;color:#8d87b4;margin-top:3px;}
.empty{color:#7d77a6;font-size:14px;text-align:center;padding:20px;}
.ins-h{font-size:12px;font-weight:700;color:#b3add6;margin:8px 0 4px;letter-spacing:.04em;}
.ins-row{display:flex;justify-content:space-between;background:rgba(255,255,255,.05);border-radius:10px;padding:10px 13px;font-size:14px;margin-bottom:5px;}
.ins-pct{font-weight:800;color:#ffd66b;font-variant-numeric:tabular-nums;}
.sharecard{background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:16px;padding:18px;color:#fff;margin-bottom:8px;}
.sc-top{font-weight:800;font-size:18px;}.sc-mid{font-size:15px;margin-top:4px;}.sc-date{font-size:12px;opacity:.85;margin-top:6px;}
.psec{background:rgba(255,255,255,.04);border-radius:16px;padding:16px;margin-bottom:4px;}
.grade-row{display:flex;gap:6px;}
.gpill{flex:1;border:1.5px solid rgba(255,255,255,.16);background:rgba(255,255,255,.05);color:#dcd8f2;border-radius:12px;padding:13px 4px;font-weight:700;font-size:14px;cursor:pointer;}
.gpill.on{background:var(--accent);border-color:var(--accent);color:#fff;}
.mot-now{font-size:14px;color:#cfcbe9;line-height:1.5;margin-bottom:10px;}
.add-row{display:flex;gap:6px;margin-top:8px;align-items:center;flex-wrap:wrap;}
.emoji-in{width:46px;text-align:center;}.lab-in{flex:1;min-width:130px;}.cost-in{width:60px;text-align:center;}
.add-row input{border:1.5px solid rgba(255,255,255,.16);background:rgba(255,255,255,.05);border-radius:10px;padding:11px;font-size:16px;color:#fff;}
.addbtn{border:none;background:var(--accent);color:#fff;border-radius:10px;padding:11px 14px;font-weight:700;cursor:pointer;}
.addbtn.full{width:100%;margin-top:8px;padding:13px;}
.ghost-btn{border:1.5px solid rgba(255,255,255,.18);background:none;color:#cfcbe9;border-radius:12px;padding:12px 16px;font-weight:600;cursor:pointer;width:100%;margin-top:8px;}
.ghost-btn.warn{border-color:rgba(255,107,107,.4);color:#ff9b9b;}
.psec.danger{background:none;}.center{text-align:center;}
.modal-bg{position:fixed;inset:0;background:rgba(8,6,18,.78);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;z-index:100;padding:20px;}
.modal{background:linear-gradient(160deg,#1c1c22,#0e0e11);border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:26px;max-width:380px;width:100%;text-align:center;box-shadow:0 30px 60px rgba(0,0,0,.5);}
.cel-emoji{font-size:58px;}.cel-title{font-size:26px;font-weight:800;margin:6px 0 4px;}
.cel-sub{font-size:14px;color:#b3add6;margin:0 0 16px;}
.cel-rewards{display:flex;justify-content:center;gap:10px;margin-bottom:16px;}
.cel-rewards span{background:rgba(255,255,255,.08);border-radius:14px;padding:10px 14px;font-weight:800;font-size:15px;}
.cel-badges{margin-bottom:16px;}.cel-bl{font-size:13px;color:#ffd66b;font-weight:700;margin:0 0 8px;}
.cel-brow{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;}
.cel-badge{background:rgba(124,92,255,.2);border:1px solid var(--accent);border-radius:14px;padding:8px 12px;font-size:13px;font-weight:600;}
.mystery{margin-bottom:18px;}
.box-btn{width:100%;border:2px dashed var(--accent2);background:rgba(124,92,255,.1);color:#fff;border-radius:16px;padding:18px;font-size:16px;font-weight:700;cursor:pointer;}
.box-open{background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:16px;padding:18px;font-size:18px;font-weight:800;}
@media(prefers-reduced-motion:reduce){*{transition:none!important;}}

/* ===== iPhone/PWA hardening ===== */
html,body{height:100%;overflow:hidden;position:fixed;inset:0;overscroll-behavior:none;-webkit-text-size-adjust:100%;}
#root{height:100%;}
.app:not(.onb){height:100%;overflow:hidden;}
.onb{min-height:100%;height:auto;overflow-y:auto;-webkit-overflow-scrolling:touch;}
.scroll{min-height:0;overscroll-behavior:contain;}
button,.mission,.opt,.checkrow,.tabbtn,.pick-face,.pick-color,.theme-row,.level-row,.gpill,.rwtab,.redeem,.addbtn,.ghost-btn,.cta,.solbtn,.back,.timer,.who,.box-btn,.switch{touch-action:manipulation;-webkit-touch-callout:none;-webkit-user-select:none;user-select:none;}
input,textarea{-webkit-user-select:text;user-select:text;}

.install-banner{position:fixed;top:0;left:0;right:0;z-index:200;background:linear-gradient(135deg,var(--accent,#7c5cff),var(--accent2,#b39dff));color:#fff;padding:10px 14px;padding-top:calc(10px + env(safe-area-inset-top));display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;line-height:1.4;}
.install-banner .ib-x{margin-left:auto;background:rgba(255,255,255,.25);border:none;color:#fff;border-radius:8px;width:26px;height:26px;flex:none;cursor:pointer;font-weight:800;}

/* ===== celebration + motivation-driven reward UI ===== */
.modal{position:relative;overflow:hidden;}
.confetti-canvas{position:absolute;inset:0;pointer-events:none;}
.pb-banner{background:linear-gradient(135deg,#ffd66b,#ff9d4d);color:#3a2400;font-weight:800;border-radius:12px;padding:10px 14px;margin-bottom:10px;font-size:14px;text-align:center;}
.next-line{background:rgba(255,255,255,.06);border-radius:12px;padding:11px 14px;font-size:13px;color:#cfcbe9;margin-top:10px;}
.next-bar{height:7px;background:rgba(255,255,255,.12);border-radius:6px;overflow:hidden;margin-top:6px;}
.next-bar>div{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.sharecard-canvas{width:100%;border-radius:16px;margin:12px 0 4px;display:block;}
.blend-toggle{display:flex;align-items:center;justify-content:space-between;gap:10px;background:rgba(255,255,255,.05);border-radius:12px;padding:12px 14px;margin-top:10px;font-size:14px;}
.sound-row{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.05);border-radius:12px;padding:12px 14px;font-size:14px;}
.switch{width:46px;height:26px;border-radius:20px;background:rgba(255,255,255,.15);position:relative;border:none;cursor:pointer;flex:none;}
.switch.on{background:var(--accent);}
.switch .knob{position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:#fff;transition:left .15s;}
.switch.on .knob{left:23px;}
.obs-row{font-size:13px;color:#cfcbe9;background:rgba(255,255,255,.05);border-radius:10px;padding:10px 13px;margin-top:8px;line-height:1.5;}
